# Docker socket path for container discovery.
# Default works on Linux and macOS (Docker Desktop).
# Windows (WSL 2): DOCKER_SOCKET=/var/run/docker.sock   (recommended)
# Windows (native): Docker Desktop named pipes are NOT supported —
#                   use WSL 2 or register Ollama as a remote instance instead.
# DOCKER_SOCKET=/var/run/docker.sock
# LLAMADECK_CONFIG_DIR=/data
# LLAMADECK_HOST=0.0.0.0
# LLAMADECK_PORT=11435
